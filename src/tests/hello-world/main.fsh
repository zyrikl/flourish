head {
    title "Hello, World!"
}
body {
    h1 "Hello, World!"
    h2 "This document demonstrates usage of Flourish."
    p "Don't you think Flourish is easier to use than your HTML boilerplate generator?"
    a href="./hello.fsh" "Go to ./hello.fsh"

    style "h1 { color: blue; } h2 { color: red; }"
}